<!DOCTYPE html><html lang="pt"><head><link rel="icon" type="image/svg+xml" href="/img/favicon.svg"><link rel="apple-touch-icon" href="/img/favicon.svg"><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Geotecnia em Brasilia | Geotecnia profissional</title><meta name="description" content="Estudo de mecânica dos solos em Brasília com ensaios de laboratório acreditados, caracterização de solos porosos do cerrado e"><link rel="canonical" href="https://brasilia.geotecnia1.org/"><meta property="og:type" content="website"><meta property="og:title" content="Geotecnia em Brasilia"><meta property="og:description" content="Estudo de mecânica dos solos em Brasília com ensaios de laboratório acreditados, caracterização de solos porosos do cerrado e"><meta property="og:url" content="https://brasilia.geotecnia1.org/"><meta property="og:site_name" content="Geotecnia1"><meta property="og:image" content="https://brasilia.geotecnia1.org/img/estudio-mecanica-suelos-5.webp"><meta property="og:locale" content="pt_BR"><meta name="twitter:card" content="summary_large_image"><meta name="twitter:title" content="Geotecnia em Brasilia"><meta name="twitter:description" content="Estudo de mecânica dos solos em Brasília com ensaios de laboratório acreditados, caracterização de solos porosos do cerrado e parâmetros geotécnicos conforme ABNT NBR 6122:2019.">
